# ─────────────────────────────────────────────
# Vonage Voice API credentials
# ─────────────────────────────────────────────
# Your Vonage Application ID (found in Vonage Dashboard)
VONAGE_APPLICATION_ID=your-vonage-application-id

# Path to your Vonage application private key file
VONAGE_PRIVATE_KEY=private.key

# An existing Vonage voice call/session ID (created by test C1 or dashboard)
VONAGE_CALL_ID=your-vonage-call-id
# Optional legacy fallback
# VONAGE_SESSION_ID=your-vonage-call-id

# Your Vonage virtual number in E.164 format (required for answer/answer.py)
VONAGE_NUMBER=+14155551234

# ─────────────────────────────────────────────
# AWS credentials
# ─────────────────────────────────────────────
# Preferred: use AWS CLI profile from ~/.aws/credentials + ~/.aws/config
AWS_PROFILE=vonage-dev
AWS_REGION=us-east-1

# Optional fallback (only if you are not using AWS_PROFILE)
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_SESSION_TOKEN=your-aws-session-token

# ─────────────────────────────────────────────
# AWS Bedrock model
# ─────────────────────────────────────────────
# Amazon Nova Sonic (speech-to-speech) — primary model for the agent
BEDROCK_MODEL_ID=amazon.nova-2-sonic-v1:0
# Initial greeting — prevents Nova Sonic 532 timeout (55s wait for first audio)
BEDROCK_INITIAL_USER_MESSAGE=Hello! How can I help you today?
# System prompt for Nova Sonic
BEDROCK_SYSTEM_INSTRUCTION=You are a helpful voice assistant. Respond warmly and briefly.
# Prompt sent to AgentCore bootstrap (local dev only, when AGENTCORE_AGENT_ARN is set)
AGENTCORE_BOOTSTRAP_PROMPT=Provide one short greeting plus one helpful follow-up question for a live voice assistant session.
# Bedrock API client tuning (retries + timeouts)
BEDROCK_CONNECT_TIMEOUT_SECONDS=10
BEDROCK_READ_TIMEOUT_SECONDS=60
BEDROCK_MAX_ATTEMPTS=4
# Validate model ID on startup; fails fast on invalid IDs
BEDROCK_VALIDATE_MODEL_ID=true

# ─────────────────────────────────────────────
# AWS Bedrock AgentCore Runtime
# ─────────────────────────────────────────────
# Local dev bootstrap (optional) — app/agent.py
AGENTCORE_AGENT_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/your-runtime-id
# Production /answer webhook (required) — answer/answer.py via App Runner
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/your-runtime-id

# ─────────────────────────────────────────────
# Nova Sonic session guard (recommended for long-lived sessions)
# ─────────────────────────────────────────────
# Emit a renewal recommendation event before session expiry window.
NOVA_SESSION_WARN_SECONDS=410
# Session-age threshold used for renewal limit behavior.
NOVA_SESSION_LIMIT_SECONDS=470
# Optional strict mode: stop pipeline when limit is reached.
NOVA_SESSION_STOP_ON_LIMIT=false

# ─────────────────────────────────────────────
# Application server
# ─────────────────────────────────────────────
PORT=8000
